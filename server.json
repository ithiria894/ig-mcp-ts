{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mcpware/instagram-mcp",
  "description": "Instagram MCP \u2014 23 tools for Instagram Graph API: posts, DMs, stories, reels, analytics.",
  "repository": {
    "url": "https://github.com/mcpware/instagram-mcp",
    "source": "github"
  },
  "version": "1.0.4",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mcpware/instagram-mcp",
      "version": "1.0.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Meta long-lived access token for Instagram Graph API",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "INSTAGRAM_ACCESS_TOKEN"
        },
        {
          "description": "Instagram business account ID",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "INSTAGRAM_ACCOUNT_ID"
        },
        {
          "description": "Instagram Graph API version (default: v19.0)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "INSTAGRAM_API_VERSION"
        }
      ]
    }
  ]
}